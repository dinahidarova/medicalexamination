# Запрещаем прямой доступ к папкам других ролей
RedirectMatch 403 ^/hms/admin/.*$
RedirectMatch 403 ^/hms/doctor/.*$
RedirectMatch 403 ^/hms/employee/.*$
RedirectMatch 403 ^/hms/laboratorist/.*$
RedirectMatch 403 ^/hms/receptionist/.*$

# Разрешаем доступ только для пациентов и index.php
<FilesMatch "^(index\.php|logout\.php)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

<FilesMatch "\.(css|js|jpg|png|gif)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
# Защита от доступа к конфигурационным файлам
<FilesMatch "^(config\.php|logging\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Запрет просмотра директорий
Options -Indexes

# Защита от XSS
Header set X-XSS-Protection "1; mode=block"

# Защита от clickjacking
Header set X-Frame-Options "SAMEORIGIN"